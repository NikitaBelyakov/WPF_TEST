<Window
    x:Class="WPF_TEST.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodel="clr-namespace:WPF_TEST.ViewModel"
    xmlns:views="clr-namespace:WPF_TEST.Views"
    d:DataContext="{d:DesignInstance Type=viewmodel:MainViewModel}"
    d:DesignHeight="1080"
    d:DesignWidth="1920"
    Background="#1e1e1e"
    DataContext="{Binding Main, Source={StaticResource Locator}}"
    WindowState="Maximized"
    WindowStyle="None"
    mc:Ignorable="d">
    <!--  СТИЛИ  -->
    <Window.Resources>
        <Style
            x:Key="ButtonStyleBlue"
            BasedOn="{StaticResource MaterialDesignRaisedLightButton}"
            TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="25"
                            SnapsToDevicePixels="True">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Offset="0" Color="#4da2db" />
                        <GradientStop Offset="1" Color="#1f86cc" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#ffffff" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style
            x:Key="ButtonStyleBase"
            BasedOn="{StaticResource MaterialDesignRaisedLightButton}"
            TargetType="Button">
            <Setter Property="Foreground" Value="#ffffff" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="BackgroundEllipse" Fill="{TemplateBinding Background}" />
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding Content}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="65" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Offset="0" Color="#0b132b" />
                    <GradientStop Offset="0.25" Color="#1c2541" />
                    <GradientStop Offset="0.5" Color="#3a506b" />
                    <GradientStop Offset="0.75" Color="#1c2541" />
                    <GradientStop Offset="1" Color="#0b132b" />
                </LinearGradientBrush>
            </Grid.Background>

            <Image
                Margin="10,10,0,0"
                HorizontalAlignment="Left"
                Opacity="1"
                Source="\imageloader.ico" />

            <Viewbox
                Grid.Row="0"
                Width="220"
                Margin="0,0,0,0"
                HorizontalAlignment="Right">
                <StackPanel Cursor="" Orientation="Horizontal">
                    <Button
                        Click="Minimize_Click"
                        Focusable="False"
                        Foreground="#ffffff"
                        Style="{StaticResource ButtonStyleBase}"
                        ToolTip="Свернуть">
                        <Viewbox Margin="10">
                            <materialDesign:PackIcon Kind="WindowMinimize" />
                        </Viewbox>
                    </Button>
                    <Button
                        Margin="0,0,0,0"
                        Click="CloseButton_Click"
                        Focusable="False"
                        Foreground="#ffffff"
                        Style="{StaticResource ButtonStyleBase}"
                        ToolTip="Закрыть">
                        <Viewbox Margin="10">
                            <materialDesign:PackIcon Kind="WindowClose" />
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Viewbox>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Offset="0" Color="#0b132b" />
                    <GradientStop Offset="0.25" Color="#1c2541" />
                    <GradientStop Offset="0.5" Color="#3a506b" />
                    <GradientStop Offset="0.75" Color="#1c2541" />
                    <GradientStop Offset="1" Color="#0b132b" />
                </LinearGradientBrush>
            </Grid.Background>
            <Grid.RowDefinitions>
                <RowDefinition Height="0.8*" />
                <RowDefinition Height="0.2*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
            </Grid.ColumnDefinitions>


            <ItemsControl Grid.Row="0" 
                          ItemsSource="{Binding ImageStates}"
                          Margin="32,24,32,16">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding ImageCount}" Rows="1"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <views:ImageCardView DataContext="{Binding}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Button
                    Grid.Row="0"
                    Width="200"
                    Height="50"
                    Command="{Binding LoadAllCommand}"
                    Content="ЗАГРУЗИТЬ ВСЕ"
                    Cursor="Hand"
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="White"
                    Style="{StaticResource ButtonStyleBlue}" />


                <ProgressBar
                    Grid.Row="1"
                    Width="1425"
                    Height="16"
                    Background="#2d2d2d"
                    Foreground="#3498db"
                    Value="{Binding TotalProgress}" />

                <TextBlock
                    Grid.Row="1"
                    Margin="0,0,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="#9d9d9d"
                    Text="{Binding TotalProgress, StringFormat={}{0:F1}%}" />

            </Grid>

        </Grid>

    </Grid>

</Window>